# OpenAI API Key
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# Model to use (optional, defaults to gpt-4o-mini which is cheap and fast)
OPENAI_MODEL=gpt-4o-mini

# Comma-separated list of website origins allowed to embed this chatbot.
# Use * for testing, restrict to your real domain(s) in production, e.g.:
# ALLOWED_ORIGINS=https://www.yourclientsite.com
ALLOWED_ORIGINS=*

# When true, /api/chat never calls OpenAI - it returns a canned message
# pointing to this GitHub repo instead. Protects API credits on a publicly
# shared demo link. Set to false to enable real live AI responses.
DEMO_MODE=false
